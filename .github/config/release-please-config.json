{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",

  "changelog-sections": [
    {"type": "feat", "section": "✨ Features"},
    {"type": "fix", "section": "🐛 Bug Fixes"},
    {"type": "deps", "section": "📦 Dependencies"},
    {"type": "docs", "section": "📚 Documentation"},
    {"type": "ci", "section": "🔄 CI/CD"},
    {"type": "test", "section": "🧪 Tests"},
    {"type": "chore", "section": "🔧 Miscellaneous"},
    {"type": "refactor", "section": "♻️ Code Refactoring"}
  ],
  "changelog-type": "default",
  "extra-label": "automerge",
  "include-v-in-tag": true,
  "packages": {
    ".": {
      "release-type": "simple",
      "package-name": "homeracker"
    },
    "cmd/scadm": {
      "release-type": "python",
      "package-name": "scadm",
      "component": "scadm"
    },
    ".github/actions/setup-openscad": {
      "release-type": "simple",
      "package-name": "setup-openscad",
      "component": "setup-openscad",
      "bump-minor-pre-major": false
    },
    ".github/actions/sync-instructions": {
      "release-type": "simple",
      "package-name": "sync-instructions",
      "component": "sync-instructions",
      "bump-minor-pre-major": false
    }
  }
}
